# MongoDB Atlas connection string (or local)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Default API port is 5050 (see server.js). Use 5050 on macOS — port 5000 is often taken by AirPlay Receiver.
PORT=5050
# Optional: CORS origin for the React app (Vite default)
CLIENT_URL=http://localhost:5173

# ChatGPT (OpenAI API) — optional; set OPENAI_API_KEY to enable server-side OpenAI calls
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
